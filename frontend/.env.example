# Optional — app works without these (email/S3/FinBERT fall back to local/simulated modes)

# Email (pick one)
GMAIL_USER=
GMAIL_APP_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SES_SENDER=
AWS_SES_TO=

# Receipt uploads
AWS_S3_BUCKET=

# Expense sentiment (FinBERT). Without this, local heuristic analysis is used.
HUGGINGFACE_API_KEY=

# Appwrite (optional — defaults are baked into src/conf/conf.js)
REACT_APP_APPWRITE_URL=
REACT_APP_APPWRITE_PROJECT_ID=
REACT_APP_APPWRITE_DATABASE_ID=
REACT_APP_APPWRITE_COLLECTION_ID=

PORT=4000
